# ══════════════════════════════════════════════════════════════════════════════
# NovaOps Environment Variables
# Copy this to .env for local dev.
# For Vercel: Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: https://app.supabase.com → Project Settings → API
NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose to the browser. Used server-side only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Square (POS) ──────────────────────────────────────────────────────────────
# From: https://developer.squareup.com → Apps → your app → Credentials
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=L...
SQUARE_APPLICATION_ID=sq0idp-...   # Optional (Web Payments SDK)

# ── Social Sign-In (Supabase Auth providers) ──────────────────────────────────
# Enable these in Supabase Dashboard → Auth → Providers, then set the flags:
NUXT_PUBLIC_SOCIAL_GOOGLE=true      # set to 'true' to show Google button on login
NUXT_PUBLIC_SOCIAL_FACEBOOK=true    # set to 'true' to show Facebook button on login

# ── Brand Manager OAuth ────────────────────────────────────────────────────────
# The base URL of your deployed app — used to build OAuth redirect_uri values.
# Must match EXACTLY what you register in each platform's developer console.
BRAND_OAUTH_REDIRECT_BASE=https://yourapp.vercel.app

# ── Facebook / Instagram (same Meta Developer App) ────────────────────────────
# From: https://developers.facebook.com → Your App → Settings → Basic
# Permissions needed: pages_manage_posts, pages_read_engagement,
#                     pages_manage_engagement, business_management
#                     instagram_basic, instagram_content_publish
# The App ID is non-secret and exposed in the browser via the runtimeConfig.
# The App Secret is server-side only.
NUXT_PUBLIC_FB_APP_ID=your-facebook-app-id      # shown in OAuth URL — non-secret
FB_APP_ID=your-facebook-app-id                  # server duplicate for convenience
FB_APP_SECRET=your-facebook-app-secret          # NEVER expose to browser

NUXT_PUBLIC_IG_APP_ID=your-instagram-app-id     # same Meta app, IG product
IG_APP_ID=your-instagram-app-id
IG_APP_SECRET=your-instagram-app-secret

# ── Google Business Profile ───────────────────────────────────────────────────
# From: https://console.cloud.google.com → APIs & Services → Credentials
# Enable: "My Business Account Management API", "My Business Business
#          Information API", "My Business Q&A API"
# OAuth scope: https://www.googleapis.com/auth/business.manage
NUXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── Yelp ─────────────────────────────────────────────────────────────────────
# From: https://www.yelp.com/developers/v3/manage_app
# Note: Yelp's public API does NOT support review reply or post publishing.
# OAuth is used only for reading business info and reviews.
NUXT_PUBLIC_YELP_CLIENT_ID=your-yelp-client-id
YELP_CLIENT_ID=your-yelp-client-id
YELP_CLIENT_SECRET=your-yelp-client-secret
